# Backend Environment Variables
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Gmail SMTP — Email Configuration
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
EMAIL_FROM_NAME=Your Name

# Redis (for BullMQ)
# Option A: Use REDIS_URL for cloud Redis (Upstash, Render, etc.)
# REDIS_URL=rediss://default:your_password@your-host.upstash.io:6379
# Option B: Use host/port for local Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Rate Limits (Gmail-safe: 80/day max, 30-60s delays)
MAX_EMAILS_PER_HOUR=50
MAX_EMAILS_PER_DAY=80
MIN_DELAY_SECONDS=30
MAX_DELAY_SECONDS=60

# File Upload
MAX_RESUME_SIZE_MB=5
UPLOAD_DIR=./uploads

# Duplicate Prevention
DUPLICATE_CHECK_DAYS=7

# Retry Config
MAX_RETRIES=3
RETRY_DELAY_1=300000
RETRY_DELAY_2=900000
RETRY_DELAY_3=1800000
